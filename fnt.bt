struct FntHeader
{
	ushort Version; Assert(Version == 0); // Guess
	ushort TexCellWidth;
	ushort TexCellHeight;
	ushort GlyphWidth;
	ushort GlyphHeight;
	ushort GlyphCount;
} Header;

struct GlyphDesc
{
	uint Character;
	ushort TexCellOffsetY;
	ushort TexCellOffsetX;
	ushort PaddingTop;
	ushort PaddingBottom;
	ushort PaddingLeft;
	ushort PaddingRight;
} Glyphs[Header.GlyphCount];